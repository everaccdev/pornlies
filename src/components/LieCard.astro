---
type CardColor = 'cream' | 'red' | 'yellow' | 'dark';

// Irregular color pattern — avoids runs of same color
const COLOR_PATTERN: CardColor[] = [
  'cream', 'red', 'dark', 'yellow',
  'red', 'cream', 'yellow', 'dark',
  'yellow', 'dark', 'cream', 'red',
];

interface Props {
  id: string;
  number: string;
  title: string;
  excerpt: string;
  slug: string;
  color?: CardColor;
  index?: number;
}

const { id, number, title, excerpt, slug, index = 0 } = Astro.props;
const color: CardColor = Astro.props.color ?? COLOR_PATTERN[index % COLOR_PATTERN.length];
---

<div
  class={`lie-card lie-card--${color}`}
  data-slug={slug}
  role="article"
  aria-label={`Lie: ${title}. Tap to reveal the truth.`}
>
  <div class="lie-card__inner">

    <!-- Front -->
    <div class="lie-card__front">
      <span class="lie-card__number">Lie No. {number}</span>
      <h3 class="lie-card__title"><em>{title}</em></h3>
    </div>

    <!-- Back -->
    <div class="lie-card__back" aria-hidden="true">
      <!-- X close button (touch devices) -->
      <button class="lie-card__close" aria-label="Close" tabindex="-1">
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
      <div class="lie-card__back-top">
        <span class="lie-card__back-label">The Truth</span>
        <p class="lie-card__back-title">{title}</p>
      </div>
      <p class="lie-card__back-excerpt">{excerpt}</p>
      <a href={slug} class="lie-card__read-more" tabindex="-1" aria-hidden="true">
        Read More <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </div>

  </div>

  <!-- X button on front (touch hint) 
  <span class="lie-card__x-hint" aria-hidden="true">
    <i class="fa-solid fa-xmark"></i>
  </span>
  -->
</div>

<script>
  document.querySelectorAll<HTMLElement>('.lie-card').forEach(card => {
    let flipped = false;
    const isTouch = () => window.matchMedia('(hover: none)').matches;

    card.addEventListener('click', (e) => {
      const slug = card.dataset.slug;
      const target = e.target as HTMLElement;

      // If close button clicked on back, unflip
      if (target.closest('.lie-card__close')) {
        e.preventDefault();
        card.classList.remove('flipped');
        flipped = false;
        return;
      }

      if (!isTouch()) {
        // Desktop: click navigates directly (hover handles flip)
        if (slug) window.location.href = slug;
        return;
      }

      // Touch: first tap flips, second tap navigates
      if (!flipped) {
        e.preventDefault();
        card.classList.add('flipped');
        flipped = true;
      } else {
        if (slug) window.location.href = slug;
      }
    });
  });
</script>

<style>
  /* X hint — top-right corner, visible on touch devices only */
  .lie-card__x-hint {
    position: absolute;
    top: 0.75rem;
    right: 0.875rem;
    font-size: 0.75rem;
    opacity: 0.35;
    z-index: 3;
    pointer-events: none;
    line-height: 1;
  }

  .lie-card--cream .lie-card__x-hint,
  .lie-card--yellow .lie-card__x-hint { color: #593230; }
  .lie-card--red .lie-card__x-hint,
  .lie-card--dark .lie-card__x-hint  { color: #F5EDD7; }

  /* Close button on back face */
  .lie-card__close {
    position: absolute;
    top: 0.75rem;
    right: 0.875rem;
    background: none;
    border: none;
    color: rgba(245, 237, 224, 0.5);
    font-size: 0.85rem;
    cursor: pointer;
    padding: 0.25rem;
    z-index: 3;
    line-height: 1;
  }
  .lie-card__close:hover { color: #F5EDD7; }
</style>
