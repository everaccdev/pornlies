---
// Valid colors from Figma design
type CardColor = 'cream' | 'red' | 'yellow' | 'dark';
const COLORS: CardColor[] = ['cream', 'red', 'yellow', 'dark'];

interface Props {
  id: string;
  number: string;
  title: string;
  excerpt: string;
  slug: string;
  color?: CardColor; // optional — random if not set
  index?: number;    // used for deterministic "random" when color omitted
}

const { id, number, title, excerpt, slug, index = 0 } = Astro.props;

// If color explicitly provided, use it. Otherwise pick deterministically
// from the 4 options based on index so SSR is consistent (no hydration mismatch).
// The sequence creates an irregular-feeling pattern across the grid.
const PATTERN: CardColor[] = ['cream', 'red', 'dark', 'yellow', 'red', 'cream', 'yellow', 'dark', 'cream', 'yellow', 'red', 'dark'];
const color: CardColor = Astro.props.color ?? PATTERN[index % PATTERN.length];
---

<!--
  Hover → flip (desktop, pointer devices)
  Touch: first tap flips, second tap navigates
-->
<div
  class={`lie-card lie-card--${color}`}
  data-slug={slug}
  role="article"
  aria-label={`Lie: ${title}. Hover or tap to reveal the truth.`}
>
  <div class="lie-card__inner">

    <!-- Front: the lie -->
    <div class="lie-card__front">
      <span class="lie-card__number">Lie No. {number}</span>
      <h3 class="lie-card__title"><em>{title}</em></h3>
    </div>

    <!-- Back: truth excerpt + read more -->
    <div class="lie-card__back" aria-hidden="true">
      <div class="lie-card__back-top">
        <span class="lie-card__back-label">The Truth</span>
        <p class="lie-card__back-title">{title}</p>
      </div>
      <p class="lie-card__back-excerpt">{excerpt}</p>
      <a href={slug} class="lie-card__read-more" tabindex="-1" aria-hidden="true">
        Read More <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </div>

  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.lie-card').forEach(card => {
    let flipped = false;
    const isTouch = () => window.matchMedia('(hover: none)').matches;

    card.addEventListener('click', (e) => {
      const slug = card.dataset.slug;

      if (!isTouch()) {
        // Desktop: hover handles flip visually, click navigates
        if (slug) window.location.href = slug;
        return;
      }

      // Touch: first tap = flip, second tap = navigate
      if (!flipped) {
        e.preventDefault();
        card.classList.add('flipped');
        flipped = true;
      } else {
        if (slug) window.location.href = slug;
      }
    });
  });
</script>
