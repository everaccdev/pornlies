---
type CardColor = 'cream' | 'red' | 'yellow' | 'dark';

// Truly irregular pattern — no two same adjacent colors
const COLOR_PATTERN: CardColor[] = [
  'cream',  'red',    'dark',   'yellow',
  'red',    'dark',   'yellow', 'cream',
  'yellow', 'cream',  'red',    'dark',
];

interface Props {
  id: string;
  number: string;
  title: string;
  excerpt: string;
  slug: string;
  color?: CardColor;
  index?: number;
}

const { id, number, title, excerpt, slug, index = 0 } = Astro.props;
const color: CardColor = Astro.props.color ?? COLOR_PATTERN[index % COLOR_PATTERN.length];
---

<div
  class={`lie-card lie-card--${color}`}
  data-slug={slug}
  role="article"
  aria-label={`Lie: ${title}. Tap to reveal the truth.`}
>
  <div class="lie-card__inner">

    <!-- Front: just number + title, no X -->
    <div class="lie-card__front">
      <span class="lie-card__number">Lie No. {number}</span>
      <h3 class="lie-card__title"><em>{title}</em></h3>
    </div>

    <!-- Back: THE LIE label + THE TRUTH label, tan text, no white/bold serif -->
    <div class="lie-card__back">
      <!-- X to flip back — essential for touch/mobile -->
      <button class="lie-card__close" aria-label="Flip back" tabindex="0">
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
      <div class="lie-card__back-top">
        <span class="lie-card__back-lie-label">The Lie</span>
        <p class="lie-card__back-lie-title">{title}</p>
        <span class="lie-card__back-truth-label">The Truth</span>
      </div>
      <p class="lie-card__back-excerpt">{excerpt}</p>
      <a href={slug} class="lie-card__read-more" tabindex="-1" aria-hidden="true">
        Read More <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </div>

  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.lie-card').forEach(card => {
    let flipped = false;
    const isTouch = () => window.matchMedia('(hover: none)').matches;

    card.addEventListener('click', (e) => {
      const slug = card.dataset.slug;
      const target = e.target as HTMLElement;

      if (target.closest('.lie-card__close')) {
        e.preventDefault();
        card.classList.remove('flipped');
        flipped = false;
        return;
      }

      if (!isTouch()) {
        if (slug) window.location.href = slug;
        return;
      }

      if (!flipped) {
        e.preventDefault();
        card.classList.add('flipped');
        flipped = true;
      } else {
        if (slug) window.location.href = slug;
      }
    });
  });
</script>

<style>
  /* X close button on back face — touch users tap to flip back */
  .lie-card__close {
    position: absolute;
    top: 0.75rem;
    right: 0.875rem;
    background: none;
    border: none;
    color: rgba(245, 237, 224, 0.6);
    font-size: 1rem;
    cursor: pointer;
    padding: 0.35rem;
    z-index: 10;
    line-height: 1;
    display: none;        /* hidden on desktop/mouse */
    align-items: center;
    justify-content: center;
  }
  /* Only show X on touchscreen devices */
  @media (hover: none) {
    .lie-card__close {
      display: flex;
    }
  }
  .lie-card__close:hover { color: #F5EDD7; }

  /* Back face labels */
  .lie-card__back-lie-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #DB0F00;            /* red for "The Lie" */
    margin-bottom: 0.3rem;
  }

  .lie-card__back-lie-title {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 400;          /* not bold */
    font-style: italic;
    color: #F5EDD7;            /* tan — no white */
    line-height: 1.3;
    margin-bottom: 1.25rem;
  }

  .lie-card__back-truth-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #FFBE00;           /* gold */
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
</style>
