---
interface Props {
  youtubeId: string;
  title: string;
  caption?: string;
}
const { youtubeId, title, caption } = Astro.props;
const embedUrl = `https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1`;
---

<div class="video-item reveal">
  <div class="video-item__embed">
    <iframe
      src={embedUrl}
      title={title}
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
  {caption && <p class="video-item__caption">{caption}</p>}
</div>

<style>
  .video-item__embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
  }

  .video-item__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .video-item__caption {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
  }
</style>
