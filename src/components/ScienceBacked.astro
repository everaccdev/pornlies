---
interface Props {
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  ctaHref = 'https://everaccountable.com/fighting-porn-together/',
  ctaLabel = 'Get Free From the Lies',
} = Astro.props;

const testimonials = [
  {
    name: 'David R.',
    location: 'Virginia',
    quote: "I'd never be here today without Ever Accountable.",
    avatar: '/images/avatar1.png',
  },
  {
    name: 'Mariah E.',
    location: 'California',
    quote: "My husband is so much happier. Our marriage is far stronger now.",
    avatar: '/images/avatar2.png',
  },
  {
    name: 'Devon B.',
    location: 'Texas',
    quote: "I was so ashamed and felt so alone. Now I'm totally free.",
    avatar: '/images/avatar3.png',
  },
];
---

<!--
  The section itself has standard padding.
  .science-testimonials-col extends 30px above and below the section
  via negative margin + padding trick, so the cards visually overflow.
-->
<section class="science-section" aria-labelledby="science-heading">

  <!-- bg image layer with color-dodge blend 
  <div class="science-bg" aria-hidden="true"></div> -->

  <div class="science-inner container">
    <div class="science-inner-content">
    <!-- Left: headline + stat + CTA -->
    <div class="science-left">
      <h2 class="science-heading" id="science-heading">
        Scientifically-backed software that dramatically reduces porn usage.
      </h2>
      <p class="science-stat">
        In fact, 63% of users reported <strong>zero porn usage</strong> after just one month.
        We guarantee significantly less porn usage or your money back.
      </p>
      <a href={ctaHref} target="_blank" rel="noopener" class="btn btn--primary">
        {ctaLabel}
      </a>
    </div>

    <!-- Right: testimonials — overflow 30px above/below section -->
    <div class="science-testimonials-col">
      {testimonials.map((t, i) => (
        <div class={`science-card science-card--${i + 1}`}>
          <div class="science-card__avatar">
            <img src={t.avatar} alt="" width="80" height="80" />
          </div>
          <!-- Vertical dashed divider -->
          <div class="science-card__divider" aria-hidden="true"></div>
          <div class="science-card__body">
            <p class="science-card__quote">"{t.quote}"</p>
            <p class="science-card__author">{t.name} <span aria-hidden="true">·</span> {t.location}</p>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<style>
  /* ── Section wrapper ─────────────────────────────────────────────────────── */
  .science-section {
    position: relative;
    padding-block: clamp(4rem, 9vw, 7rem);
    overflow: visible; /* allow testimonials col to bleed out */
    isolation: isolate;
  }

  /* ── Background: texture-paint.png with color-dodge blend ───────────────── */
  .science-bg {
    position: absolute;
    inset: 0;
    background-color: #2a0e0e;
    background-image: url('/images/bg-science.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    mix-blend-mode: color-dodge;
    opacity: 0.18;
    z-index: -1;
  }

  /* Dark base behind the blend */
  .science-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: transparent;
    z-index: -2;
  }

  /* ── Inner grid ──────────────────────────────────────────────────────────── */
  .science-inner {
    background-color: #2a0e0e;
    margin:0 0 0 0;
    max-width:100%;
    justify-items:center;
    padding:.5rem;
  }

  .science-inner-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: center;
    max-width:1200px;
  }

  @media (max-width: 860px) {
    .science-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* ── Left: text ─────────────────────────────────────────────────────────── */
  /* Figma: Crimson Pro 500, 40px, line-height 1, letter-spacing -0.5px, #F5EDD7 */
  .science-heading {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    font-weight: 500;
    color: #F5EDD7;
    line-height: 1;
    letter-spacing: -0.5px;
    margin-bottom: 1.25rem;
  }

  .science-stat {
    font-size: clamp(0.9rem, 1.4vw, 1rem);
    color: rgba(245, 237, 224, 0.75);
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .science-stat strong {
    color: #F5EDD7;
    font-weight: 700;
  }

  /* ── Right: testimonials column with 30px vertical overflow ─────────────── */
  .science-testimonials-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    /* Extend above and below the section */
    margin-block: -90px;
    padding-block: 70px;
  }

  /* ── Individual testimonial card ─────────────────────────────────────────── */
  /* Skinnier & thicker than before — more landscape ratio */
  .science-card {
    display: flex;
    align-items: center;        /* vertically center avatar */
    gap: 0;                   
    background-color: #593230;
    border-radius: 3px;
    padding: 1.5rem 1.8rem;
    min-height: 88px;
    transition: transform 0.3s ease;
  }

  /* Card slant */
  .science-card--1 { transform: rotate(-1.8deg) translateY(0); }
  .science-card--2 { transform: rotate(1.4deg)  translateY(0); }
  .science-card--3 { transform: rotate(-1.2deg) translateY(0); }

  .science-card:hover {
    transform: rotate(0deg) scale(1.01) translateY(0);
  }

  /* Avatar: 80×80, centered vertically */
  .science-card__avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    background: rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .science-card__avatar img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    display: block;
  }

  /* Vertical dashed divider between avatar and text */
  .science-card__divider {
    width: 1px;
    align-self: stretch;
    margin-inline: 1.25rem;
    flex-shrink: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      rgba(245, 237, 224, 0.3) 0px,
      rgba(245, 237, 224, 0.3) 4px,
      transparent 4px,
      transparent 10px
    );
  }

  /* Body */
  .science-card__body {
    flex: 1;
    min-width: 0;
  }

  /* Quote — Crimson Pro */
  .science-card__quote {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1.1rem;
    font-style: normal;
    font-weight: 400;
    color: #F5EDD7;
    line-height: 1.5;
    margin-bottom: 0.4rem;
  }

  /* Author — uppercase gold */
  .science-card__author {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #FFBE00;
  }
</style>
