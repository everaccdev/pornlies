---
interface Testimonial {
  name: string;
  location: string;
  quote: string;
  initials: string;
  avatarColor: string;
}

interface Props {
  testimonials?: Testimonial[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  testimonials = [
    { name: 'David R.',  location: 'Virginia',    quote: "I'd never be here today without Ever Accountable.", initials: 'DR', avatarColor: '#7BAFD4' },
    { name: 'Mariah B.', location: 'California',  quote: "My husband is so much happier. Our marriage is far stronger now.", initials: 'MB', avatarColor: '#B87BA4' },
    { name: 'Devon B.',  location: 'Texas',       quote: "I was so ashamed and felt so alone. Now I'm totally free.", initials: 'DB', avatarColor: '#D4776A' },
  ],
  ctaHref = 'https://everaccountable.com/fighting-porn-together/',
  ctaLabel = 'Get Free From the Lies',
} = Astro.props;
---

<section class="science-section" aria-labelledby="science-heading">
  <div class="science-inner">

    <!-- Left: headline + stat + CTA -->
    <div class="science-left reveal">
      <h2 class="science-heading" id="science-heading">
        Scientifically-backed software that dramatically reduces porn usage.
      </h2>
      <p class="science-stat">
        In fact, 63% of users reported <strong>zero porn usage</strong> after just one month.
        We guarantee significantly less porn usage or your money back.
      </p>
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener"
        class="btn btn--primary"
      >
        {ctaLabel}
      </a>
    </div>

    <!-- Right: stacked testimonial cards, bleed top/bottom -->
    <div class="science-right">
      {testimonials.map((t, i) => (
        <div class={`science-card reveal animate-fadeup--delay-${i + 1}`}>
          <!-- Avatar circle with colored bg + initials -->
          <div class="science-card__avatar" style={`background-color: ${t.avatarColor}`}>
            <span class="science-card__initials">{t.initials}</span>
          </div>

          <!-- Dashed vertical divider -->
          <div class="science-card__divider" aria-hidden="true"></div>

          <!-- Quote + attribution -->
          <div class="science-card__body">
            <p class="science-card__quote">"{t.quote}"</p>
            <p class="science-card__author">
              {t.name} <span class="science-card__dot">·</span> {t.location}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .science-section {
    /* Correct dark maroon — NOT near-black */
    background-color: #2d1010;
    background-image: url('/images/textures/texture-paint.png');
    background-size: cover;
    background-position: center;
    background-blend-mode: multiply;
    position: relative;
    padding-block: clamp(4rem, 9vw, 7rem);
    overflow: visible; /* allow cards to bleed */
  }

  .science-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2.5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: center;
  }

  @media (max-width: 860px) {
    .science-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* ── Left column ── */
  /* Figma: Crimson Pro, weight 500, 40px, line-height 40px (1:1), letter-spacing -0.5px, color #F5EDD7 */
  .science-heading {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    font-weight: 500;
    color: #F5EDD7;
    line-height: 1;
    letter-spacing: -0.5px;
    margin-bottom: 1.25rem;
  }

  .science-stat {
    font-size: clamp(0.9rem, 1.4vw, 1rem);
    color: rgba(245, 237, 224, 0.75);
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .science-stat strong {
    color: var(--color-white);
    font-weight: 700;
  }

  /* ── Right column: testimonial cards ── */
  .science-right {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    /* Bleed cards beyond the section top/bottom */
    margin-block: -3rem;
    padding-block: 0.5rem;
  }

  @media (max-width: 860px) {
    .science-right {
      margin-block: 0;
    }
  }

  /* ── Individual testimonial card ── */
  .science-card {
    display: flex;
    align-items: center;
    gap: 0;
    background: #3d1818;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    overflow: hidden;
  }

  /* Avatar circle */
  .science-card__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 1.25rem;
  }

  .science-card__initials {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.02em;
  }

  /* Dashed vertical divider */
  .science-card__divider {
    width: 0;
    height: 44px;
    border-left: 1.5px dashed rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
    margin-right: 1.25rem;
  }

  /* Body */
  .science-card__body {
    flex: 1;
  }

  .science-card__quote {
    font-size: 0.975rem;
    color: var(--color-text);
    line-height: 1.55;
    margin-bottom: 0.5rem;
    font-style: normal;
  }

  .science-card__author {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
  }

  .science-card__dot {
    margin-inline: 0.3em;
    opacity: 0.6;
  }
</style>
