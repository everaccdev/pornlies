---
import BaseLayout from '../layouts/BaseLayout.astro';
import LieCard from '../components/LieCard.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import LeadForm from '../components/LeadForm.astro';
import ScienceBacked from '../components/ScienceBacked.astro';

const videos = [
  { id: '1', title: "Porn Won't Affect You",        youtubeId: 'pHuvOw6nRCA'  },
  { id: '2', title: "No One Will Ever Know",         youtubeId: 'Cx6ImCzKdwI' },
  { id: '3', title: "Porn Won't Hurt You",           youtubeId: 'T2m8LdgEu4Y' },
  { id: '4', title: "Porn Makes You Better in Bed",  youtubeId: '0_GZh51MnNo' },
  { id: '5', title: "Everyone Does It",              youtubeId: 'SiKNEvNZk8M' },
];

const lies = [
  { id: 'wont-hurt',                 number: '291',  title: "A little porn won't hurt you",      color: 'cream'  as const, slug: '/lies/wont-hurt',                 excerpt: "Porn trains your brain to feel entitled to other people's bodies. Even occasional use rewires your reward system — and the habit almost never stays little." },
  { id: 'nobody-will-ever-know',     number: '421',  title: "No one will ever know",              color: 'red'    as const, slug: '/lies/nobody-will-ever-know',     excerpt: "Secrets have a way of spilling out. And even if no one ever catches you — you'll know. Your inner self will always know the truth." },
  { id: 'better-in-bed',             number: '1025', title: "Porn makes you better in bed",      color: 'dark'   as const, slug: '/lies/better-in-bed',             excerpt: "Porn can harm your ability to enjoy real intimacy. It trains you for a fantasy that leaves genuine connection feeling inadequate." },
  { id: 'quit-when-married',         number: '54',   title: "I'll quit when I get married",      color: 'yellow' as const, slug: '/lies/quit-when-married',         excerpt: "The craving won't go away. People do not quit when they get married — they too often find that porn has harmed their ability to be sexual in healthy, bonding ways." },
  { id: 'everyone-does-it',          number: '332',  title: "Everyone does it",                   color: 'cream'  as const, slug: '/lies/everyone-does-it',          excerpt: "Porn's popularity doesn't make it safe or healthy. A growing number of people are committed to quitting permanently." },
  { id: 'only-men-watch',            number: '87',   title: "Only men watch porn",                color: 'red'    as const, slug: '/lies/only-men-watch',            excerpt: "This is a common falsehood that traps many women in secrecy, fear, and shame. If you're a woman struggling with porn, you aren't alone." },
  { id: 'not-your-kids',             number: '89',   title: "Your kids will never use porn",      color: 'dark'   as const, slug: '/lies/not-your-kids',             excerpt: "In the UK, 75% of parents believed their kids would never get into porn. When they talked to their children, 53% had already viewed it." },
  { id: 'make-me-happy',             number: '77',   title: "Porn makes you happy",               color: 'yellow' as const, slug: '/lies/make-me-happy',             excerpt: "Porn offers short-term feelings of relief but no long-term solutions. Research shows pornography can lead to depression and loneliness." },
  { id: 'women-like-aggressive-men', number: '204',  title: "Girls like men who are aggressive",  color: 'cream'  as const, slug: '/lies/women-like-aggressive-men', excerpt: "Porn has become the leading sex educator for young people. It's grooming young women to accept violent sexual behavior." },
  { id: 'doesnt-hurt-anyone',        number: '613',  title: "Porn doesn't hurt anyone",           color: 'red'    as const, slug: '/lies/doesnt-hurt-anyone',        excerpt: "Victims of porn speak up and speak out as worldwide porn use spreads. Children, partners, performers — the harm flows in every direction." },
  { id: 'worthless',                 number: '156',  title: "You're worthless",                   color: 'dark'   as const, slug: '/lies/worthless',                excerpt: "There's a biological reason you keep turning back to porn. You can conquer it with the right tools and help. You don't have to feel stuck anymore." },
  { id: 'not-enough',                number: '302',  title: "You're not enough for him",          color: 'yellow' as const, slug: '/lies/not-enough',               excerpt: "His porn problem is his problem and has nothing to do with you — even though it affects you. You are worthy of love and acceptance." },
];
---

<BaseLayout
  title="PornLies — Porn lies. A lot."
  description="Porn tells you lies. See through them, find the truth, and get free with Ever Accountable."
  currentPage="/"
>

  <!-- ── Hero: texture bg, title, subtitle, single video, guide CTA ─────── -->
  <section class="hero">

    <!-- Texture image: sits at top, no-repeat, shows white not black -->
    <div class="hero__texture" aria-hidden="true"></div>

    <div class="hero__content container">
      <h1 class="hero__title animate-fadeup">
        Porn <span class="text-red">lies.</span> A lot.
      </h1>
      <p class="hero__subtitle animate-fadeup animate-fadeup--delay-1">
        <em>If porn could talk…</em>
      </p>
    </div>

    <!-- Single hero video -->
    <div class="hero__video animate-fadeup animate-fadeup--delay-2">
      <VideoEmbed youtubeId={videos[0].youtubeId} title={videos[0].title} />
    </div>

    <!-- Guide CTA below video -->
    <div class="hero__cta container animate-fadeup animate-fadeup--delay-3">
      <p class="guide-label">Download the guide:</p>
      <a href="#download" class="btn btn--red hero__cta-btn">
        5 Things You Can Do Today to Kick Porn to the Curb
      </a>
      <a href="/videos" class="btn btn--outline hero__cta-ghost">
        View All Videos <i class="fa-solid fa-arrow-down" aria-hidden="true"></i>
      </a>
    </div>

  </section>

  <!-- ── Scientifically Backed ─────────────────────────────────────────── -->
  <ScienceBacked />

  <!-- ── More Videos: 2+2 ──────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="video-grid">
        <VideoEmbed youtubeId={videos[1].youtubeId} title={videos[1].title} />
        <VideoEmbed youtubeId={videos[2].youtubeId} title={videos[2].title} />
      </div>
      <div class="video-grid" style="margin-top: 1.5rem;">
        <VideoEmbed youtubeId={videos[3].youtubeId} title={videos[3].title} />
        <VideoEmbed youtubeId={videos[4].youtubeId} title={videos[4].title} />
      </div>
      <div class="text-center mt-lg">
        <a href="https://everaccountable.com/fighting-porn-together/" target="_blank" rel="noopener" class="btn btn--primary">
          Get Free From Lies
        </a>
      </div>
    </div>
  </section>

  <!-- ── Download Guide form ───────────────────────────────────────────── -->
  <section class="section section--dark" id="download" aria-labelledby="guide-heading">
    <div class="container" style="max-width: 800px;">
      <div class="text-center">
        <p class="cta-block__eyebrow">Download the Guide:</p>
        <h2 class="cta-block__title" id="guide-heading">Ways to Kick Porn to the Curb Today</h2>
        <LeadForm id="guide-form" submitLabel="Get the Free Guide" />
      </div>
    </div>
  </section>

  <!-- ── Lies Grid ─────────────────────────────────────────────────────── -->
  <section class="section" aria-labelledby="lies-heading">
    <div class="container">
      <div class="lies-section__header">
        <h2 id="lies-heading">More <span class="text-red">Lies</span></h2>
        <p class="lies-section__subtitle"><em>Click a Lie to Reveal the Truth</em></p>
      </div>
      <div class="lies-grid">
        {lies.map((lie, i) => (
          <div class="reveal">
            <LieCard
              id={lie.id}
              number={lie.number}
              title={lie.title}
              color={lie.color}
              index={i}
              slug={lie.slug}
              excerpt={lie.excerpt}
            />
          </div>
        ))}
      </div>
      <div class="text-center mt-lg">
        <a href="/lies" class="btn btn--outline">
          See All Lies <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </section>



</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    text-align: center;
    padding-bottom: clamp(3rem, 6vw, 5rem);
    overflow: hidden;
  }

  /* Texture: paint image, top-aligned, screen blend so only whites show */
  .hero__texture {
    position: absolute;
    inset: 0;
    bottom: auto;
    height: 100%;
    min-height: 700px;
    background-image: url('/images/textures/texture-grain.png');
    background-size: cover;
    background-position: top center;
    background-repeat: no-repeat;
    mix-blend-mode: screen;
    opacity: 0.45;
    pointer-events: none;
    z-index: 0;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-top: clamp(0.5rem, 2vw, 1.5rem);   /* minimal — hero starts near top */
    padding-bottom: 2rem;
  }

  /* Title: 120px desktop */
  :global(.hero__title) {
    font-size: clamp(3.5rem, 10vw, 7.5rem) !important;
    line-height: 1.0 !important;
    white-space: nowrap;
    color: #F5EDD7 !important;
    font-weight: 700 !important;
    margin-bottom: 0.5rem !important;
    letter-spacing: -0.03em !important;
  }

  @media (max-width: 700px) {
    :global(.hero__title) {
      white-space: normal !important;
      font-size: clamp(2.8rem, 12vw, 5rem) !important;
    }
  }

  /* Subtitle: Crimson Pro italic, 64px desktop */
  :global(.hero__subtitle) {
    font-family: 'Crimson Pro', Georgia, serif !important;
    font-size: clamp(1.5rem, 4.5vw, 4rem) !important; /* ~64px at 1400px */
    font-style: italic !important;
    font-weight: 400 !important;
    color: #F5EDD7 !important;
    margin-bottom: 3rem !important;
    line-height: 1.15 !important;
  }

  /* Single hero video */
  .hero__video {
    position: relative;
    z-index: 1;
    width: min(760px, 90%);
    margin-inline: auto;
    margin-bottom: 2.5rem;
  }

  /* Guide CTA block below video */
  .hero__cta {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 560px;
    margin-inline: auto;
  }

  .hero__cta-label {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    font-style: italic;
    color: #F5EDD7;
    margin: 0;
  }

  .hero__cta-btn {
    width: 100%;
    font-size: 0.95rem;
    padding: 1rem 1.5rem;
    border-radius: 4px;
    white-space: normal;
    line-height: 1.3;
  }

  .hero__cta-ghost {
    width: 100%;
    padding: 0.85rem 1.5rem;
  }
  .guide-form-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #FFBE00;
    margin-bottom: 0.4rem;
  }
  .guide-form-title {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 500;
    font-style: italic;
    color: #F5EDD7;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
    line-height: 1.2;
  }
</style>