---
import BaseLayout from '../layouts/BaseLayout.astro';
import LieCard from '../components/LieCard.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import LeadForm from '../components/LeadForm.astro';

// ─── Videos ───────────────────────────────────────────────────────────────────
// Edit in /src/content/videos/videos.md (or via CMS at /admin)
// Replace youtube_id values with the real IDs from the current pornlies.com videos.
// To find a YouTube video ID: in https://youtube.com/watch?v=XXXXX  the ID is XXXXX
const videos = [
  { id: '1', title: 'Porn Won\'t Affect You', youtubeId: 'REPLACE_VIDEO_ID_1', caption: 'Download the guide: 5 Things You Can Do Today to Kick Porn to the Curb' },
  { id: '2', title: 'No One Will Ever Know',  youtubeId: 'REPLACE_VIDEO_ID_2', caption: 'Download the guide: 5 Things You Can Do Today to Kick Porn to the Curb' },
];

// ─── Testimonials ─────────────────────────────────────────────────────────────
// Edit in /src/content/testimonials/testimonials.md (or via CMS at /admin)
const testimonials = [
  { name: 'David R.',  location: 'Virginia',    quote: "I'd never be here today without Ever Accountable." },
  { name: 'Mariah B.', location: 'California',  quote: "My husband is so much happier. Our marriage is far stronger now." },
  { name: 'Devon B.',  location: 'Texas',       quote: "I was so ashamed and felt so alone. Now I'm totally free." },
];

// ─── Lies Grid ────────────────────────────────────────────────────────────────
// Edit in /src/content/lies/lies.md (or via CMS at /admin)
const lies = [
  { id: 'wont-hurt',            number: '291',  title: "A little porn won't hurt you",  color: 'cream'  as const, slug: '/lies/wont-hurt',            excerpt: "Porn promises it's harmless—just entertainment, just stress relief. But science tells a very different story about what even occasional use does to the brain." },
  { id: 'nobody-will-ever-know', number: '421', title: "No one will ever know",          color: 'red'    as const, slug: '/lies/nobody-will-ever-know', excerpt: "Secrecy is one of porn's most powerful tools. It whispers that what happens in private stays private—but secrets change us from the inside out." },
  { id: 'better-in-bed',        number: '1025', title: "Porn makes you better in bed",  color: 'dark'   as const, slug: '/lies/better-in-bed',         excerpt: "Far from being a sex-ed tool, pornography consistently produces worse real-world sexual outcomes and sets unrealistic expectations." },
  { id: 'everyone-does-it',     number: '332',  title: "Everyone does it",               color: 'yellow' as const, slug: '/lies/everyone-does-it',      excerpt: "Porn normalizes itself by claiming universality. But 'everyone does it' is both factually wrong and morally irrelevant." },
  { id: 'quit-when-married',    number: '54',   title: "I'll quit when I get married",  color: 'cream'  as const, slug: '/lies/quit-when-married',     excerpt: "This lie lets you off the hook from the hard work of change right now—promising a future event will solve a present problem." },
  { id: 'only-men-watch',       number: '87',   title: "Only men watch porn",            color: 'red'    as const, slug: '/lies/only-men-watch',         excerpt: "Women are one of the fastest-growing demographics in porn consumption, and many suffer in silence because the script says it isn't their struggle." },
];
---

<BaseLayout
  title="PornLies — Porn lies. A lot."
  description="Porn tells you lies. See through them, find the truth, and get free with Ever Accountable."
  currentPage="/"
>

  <!-- ── Hero ── -->
  <section class="hero section section--textured">
    <div class="container">
      <span class="hero__eyebrow animate-fadeup">If porn could talk…</span>
      <h1 class="hero__title animate-fadeup animate-fadeup--delay-1">
        Porn <span class="text-red">lies.</span><br />A lot.
      </h1>
      <p class="hero__subtitle animate-fadeup animate-fadeup--delay-2">
        <em>See through the lies. Find the truth. Get free.</em>
      </p>
      <div class="flex-center gap-md animate-fadeup animate-fadeup--delay-3">
        <a href="#download" class="btn btn--red">
          <i class="fa-solid fa-download" aria-hidden="true"></i>
          Download the Free Guide
        </a>
        <a href="/lies" class="btn btn--outline">
          See All the Lies <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Videos ── -->
  <section class="section section--dark" aria-labelledby="videos-heading">
    <div class="container">
      <div class="text-center" style="margin-bottom: 3rem;">
        <h2 id="videos-heading">The Lies, In Character</h2>
        <p style="margin-top: 0.5rem; color: var(--color-text-muted);">
          <em>If porn could talk, this is what it would say.</em>
        </p>
      </div>

      <div class="video-grid">
        {videos.map(v => (
          <VideoEmbed youtubeId={v.youtubeId} title={v.title} caption={v.caption} />
        ))}
      </div>

      <div class="text-center mt-md">
        <a href="#download" class="guide-banner">
          <i class="fa-solid fa-file-arrow-down" aria-hidden="true"></i>
          5 Things You Can Do Today to Kick Porn to the Curb
        </a>
      </div>
    </div>
  </section>

  <!-- ── Download Guide + Testimonials ── -->
  <section class="section" id="download" aria-labelledby="guide-heading">
    <div class="container">
      <div class="split-layout">
        <div class="reveal">
          <LeadForm
            id="guide-form"
            title="Ways to Kick Porn to the Curb Today"
            subtitle="Free guide — delivered straight to your inbox."
            submitLabel="Get the Free Guide"
          />
        </div>

        <div>
          <div class="stat-callout reveal" style="margin-bottom: 2rem;">
            <div class="stat-callout__number">63%</div>
            <div class="stat-callout__text">
              of Ever Accountable users reported <strong>zero porn usage</strong> after just one month.
              We guarantee significantly less porn usage or your money back.
            </div>
          </div>

          <div class="testimonials-grid">
            {testimonials.map((t, i) => (
              <div class={`reveal animate-fadeup--delay-${i + 1}`}>
                <TestimonialCard name={t.name} location={t.location} quote={t.quote} />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── More Lies Grid ── -->
  <section class="lies-section section--dark" aria-labelledby="lies-heading">
    <div class="container">
      <div class="lies-section__header">
        <h2 id="lies-heading">More <span class="text-red">Lies</span></h2>
        <p class="lies-section__subtitle"><em>Click a Lie to Reveal the Truth</em></p>
      </div>

      <div class="lies-grid">
        {lies.map(lie => (
          <div class="reveal">
            <LieCard
              id={lie.id}
              number={lie.number}
              title={lie.title}
              color={lie.color}
              slug={lie.slug}
              excerpt={lie.excerpt}
            />
          </div>
        ))}
      </div>

      <div class="text-center mt-lg">
        <a href="/lies" class="btn btn--outline">
          See All Lies <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Newsletter ── -->
  <section class="section" aria-labelledby="newsletter-heading">
    <div class="container">
      <div class="cta-block">
        <p class="cta-block__eyebrow">Want to Stay Connected?</p>
        <h2 class="cta-block__title" id="newsletter-heading">
          Sign up to receive<br />news and updates
        </h2>
        <LeadForm id="newsletter-form" submitLabel="Sign Up" />
      </div>
    </div>
  </section>

</BaseLayout>
