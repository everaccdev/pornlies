---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LieCard from '../../components/LieCard.astro';

// All 12 lies — matches current site exactly
// Colors follow an irregular pattern matching the Figma design
const lies = [
  { id: 'wont-hurt',              number: '291',  title: "A little porn won't hurt you",   color: 'cream'  as const, slug: '/lies/wont-hurt',              excerpt: "Porn trains your brain to feel entitled to other people's bodies. Even occasional use rewires your reward system — and the habit almost never stays little." },
  { id: 'nobody-will-ever-know',  number: '421',  title: "No one will ever know",           color: 'red'    as const, slug: '/lies/nobody-will-ever-know',   excerpt: "Secrets have a way of spilling out. And even if no one ever catches you — you'll know. Your inner self will always know the truth." },
  { id: 'better-in-bed',          number: '1025', title: "Porn makes you better in bed",   color: 'dark'   as const, slug: '/lies/better-in-bed',           excerpt: "Porn can harm your ability to enjoy real intimacy. It trains you for a fantasy that leaves genuine connection feeling inadequate." },
  { id: 'quit-when-married',      number: '54',   title: "I'll quit when I get married",   color: 'cream'  as const, slug: '/lies/quit-when-married',        excerpt: "The craving won't go away. People do not quit when they get married — they too often find that porn has harmed their ability to be sexual in healthy, bonding ways." },
  { id: 'everyone-does-it',       number: '332',  title: "Everyone does it",                color: 'yellow' as const, slug: '/lies/everyone-does-it',         excerpt: "Porn's popularity doesn't make it safe or healthy. A growing number of people are committed to quitting permanently — clearly not everybody watches porn." },
  { id: 'only-men-watch',         number: '87',   title: "Only men watch porn",             color: 'red'    as const, slug: '/lies/only-men-watch',           excerpt: "This is a common falsehood that traps many women in secrecy, fear, and shame. If you're a woman struggling with porn, you aren't alone." },
  { id: 'not-your-kids',          number: '89',   title: "Your kids will never use porn",   color: 'dark'   as const, slug: '/lies/not-your-kids',            excerpt: "In the UK, 75% of parents believed their kids would never get into porn. When they talked to their children, they found 53% had already viewed it." },
  { id: 'make-me-happy',          number: '77',   title: "Porn makes you happy",            color: 'yellow' as const, slug: '/lies/make-me-happy',            excerpt: "Porn offers short-term feelings of relief but no long-term solutions. Research has shown that pornography can lead to mental health challenges, like depression." },
  { id: 'women-like-aggressive-men', number: '204', title: "Girls like men who are aggressive", color: 'cream' as const, slug: '/lies/women-like-aggressive-men', excerpt: "Porn has become the leading sex educator for young people. It's grooming young women to accept violent sexual behavior — and that is a lie." },
  { id: 'doesnt-hurt-anyone',     number: '613',  title: "Porn doesn't hurt anyone",        color: 'red'    as const, slug: '/lies/doesnt-hurt-anyone',       excerpt: "Victims of porn speak up and speak out as worldwide porn use spreads. Children, partners, performers — the harm flows in every direction." },
  { id: 'worthless',              number: '156',  title: "You're worthless",                color: 'dark'   as const, slug: '/lies/worthless',               excerpt: "You need to know there's a biological reason you keep turning back to porn. You can conquer it with the right tools and help. You don't have to feel stuck anymore." },
  { id: 'not-enough',             number: '302',  title: "You're not enough for him",       color: 'yellow' as const, slug: '/lies/not-enough',              excerpt: "His porn problem is his problem and has nothing to do with you — even though it affects you. You are worthy of love and acceptance." },
];
---

<BaseLayout
  title="The Lies — PornLies"
  description="Porn tells you lies. Here they all are — with the truth behind each one."
  currentPage="/lies"
>
  <div class="page-hero section section--textured">
    <div class="container">
      <h1 class="page-hero__title">
        Porn <span class="text-red">lies.</span> A lot.
      </h1>
      <p class="page-hero__subtitle"><em>Click any lie to reveal the truth.</em></p>
    </div>
  </div>

  <section class="section section--dark" aria-label="All lies">
    <div class="container">
      <div class="lies-grid">
        {lies.map((lie, i) => (
          <div class="reveal">
            <LieCard
              id={lie.id}
              number={lie.number}
              title={lie.title}
              color={lie.color}
              index={i}
              slug={lie.slug}
              excerpt={lie.excerpt}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
