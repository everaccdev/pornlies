---
// src/pages/lies/[slug].astro
// Astro static site generation — one page built per lie at build time.
// To add a new lie: add it to the `lies` array below (and to the CMS config).

import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';

// ─── All Lie Data ────────────────────────────────────────────────────────────
