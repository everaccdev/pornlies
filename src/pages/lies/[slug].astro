    font-size: clamp(2rem, 5vw, 3.5rem);
    font-style: italic;
    font-weight: 400;
    color: #F5EDD7;
    max-width: 800px;
    margin-inline: auto;
    line-height: 1.15;
  }

  .lie-detail-content {
    max-width: 700px;
    margin-inline: auto;
  }
  .lie-detail-content p {
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 1.75rem;
  }

  .lie-detail-cta {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 2.5rem;
    margin-block: 3rem;
    text-align: center;
  }
  .lie-detail-cta h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.75rem;
  }
  .lie-detail-cta p {
    color: var(--color-text-muted);
    max-width: 480px;
    margin-inline: auto;
    margin-bottom: 1.5rem;
    font-size: 0.95rem !important;
  }

  .lie-detail-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 2.5rem;
    border-top: 1px solid rgba(255,255,255,0.07);
    margin-top: 1rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .lie-nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
    max-width: 240px;
    text-decoration: none;
  }
  .lie-nav-link:hover { color: var(--color-text); }
  .lie-nav-link span {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .lie-nav-link small {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-red);
  }
  .lie-nav-link strong {
    font-size: 0.85rem;
    font-weight: 600;
  }
  .lie-nav-link--next {
    text-align: right;
  }
  .lie-nav-link--next span { align-items: flex-end; }
</style>
