export function getStaticPaths() {
  return lies.map(lie => ({
    params: { slug: lie.slug },
    props: { lie },
  }));
}

const { lie } = Astro.props;

const currentIndex = lies.findIndex(l => l.slug === lie.slug);
const prevLie = currentIndex > 0 ? lies[currentIndex - 1] : null;
const nextLie = currentIndex < lies.length - 1 ? lies[currentIndex + 1] : null;

const colorAccent: Record<string, string> = {
  cream: '#DB0F00',
  red:   '#FFBE00',
  yellow:'#1a0a0a',
  dark:  '#F1F1F1',
};
---

<BaseLayout
  title={`${lie.title} — PornLies`}
  description={lie.excerpt}
  currentPage="/lies"
>

  <!-- Hero -->
  <section class="lie-detail-hero section--textured">
    <div class="container">
      <p class="lie-detail-hero__number animate-fadeup">Lie No. {lie.number}</p>
      <h1 class="lie-detail-hero__title animate-fadeup animate-fadeup--delay-1">
        <em>"{lie.title}"</em>
      </h1>
    </div>
  </section>

  <!-- Content -->
  <section class="section">
    <div class="container">
      <div class="lie-detail-content">

        {lie.paragraphs.map((para, i) => (
          <p class="reveal" style={`transition-delay: ${i * 0.07}s`}>{para}</p>
        ))}

        <!-- CTA -->
        <div class="lie-detail-cta reveal">
          <p class="cta-block__eyebrow">Ready to get free?</p>
          <h2>Kick porn to the curb.</h2>
          <p>Scientifically-backed accountability software that dramatically reduces porn usage. 63% of users report zero porn use after one month. Guaranteed.</p>
          <a
            href="https://everaccountable.com/fighting-porn-together/"
            target="_blank"
            rel="noopener"
            class="btn btn--primary"
          >
            Get Free From Lies
          </a>
        </div>

        <!-- Prev / Next -->
        <nav class="lie-detail-nav" aria-label="Previous and next lies">
          <div>
            {prevLie && (
              <a href={`/lies/${prevLie.slug}`} class="lie-nav-link lie-nav-link--prev">
                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                <span>
                  <small>Previous lie</small>
                  <strong>{prevLie.title}</strong>
                </span>
              </a>
            )}
          </div>
          <a href="/lies" class="btn btn--outline btn--sm">All Lies</a>
          <div>
            {nextLie && (
              <a href={`/lies/${nextLie.slug}`} class="lie-nav-link lie-nav-link--next">
                <span>
                  <small>Next lie</small>
                  <strong>{nextLie.title}</strong>
                </span>
                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
              </a>
            )}
          </div>
        </nav>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
