// Tell Astro which paths to generate
export function getStaticPaths() {
  return lies.map(lie => ({
    params: { slug: lie.slug },
    props: { lie },
  }));
}

const { lie } = Astro.props;
const colorMap: Record<string, string> = {
  cream: '#f0e8d8',
  red: '#c0392b',
  yellow: '#d4a017',
  dark: '#4a3030',
};
const cardColor = colorMap[lie.color] ?? '#f0e8d8';

// Find adjacent lies for prev/next nav
const currentIndex = lies.findIndex(l => l.slug === lie.slug);
const prevLie = currentIndex > 0 ? lies[currentIndex - 1] : null;
const nextLie = currentIndex < lies.length - 1 ? lies[currentIndex + 1] : null;
---

<BaseLayout
  title={`${lie.title} — PornLies`}
  description={lie.excerpt}
  currentPage="/lies"
>
  <!-- Lie Hero -->
  <section class="section section--textured lie-detail__hero-section" style={`background-color: ${cardColor}18`}>
    <div class="container">
      <div class="lie-detail__hero">
        <p class="lie-detail__number animate-fadeup">Lie No. {lie.number}</p>
        <h1 class="animate-fadeup animate-fadeup--delay-1" style="color: var(--color-white);">
          <em>"{lie.title}"</em>
        </h1>
        <p class="hero__subtitle animate-fadeup animate-fadeup--delay-2">The Truth</p>
      </div>
    </div>
  </section>

  <!-- Lie Full Content -->
  <section class="section">
    <div class="container">
      <div class="lie-detail__content">
        {lie.paragraphs.map((para, i) => (
          <p class="reveal" style={`transition-delay: ${i * 0.08}s`}>{para}</p>
        ))}

        <!-- CTA -->
        <div class="lie-detail__cta reveal">
          <div class="cta-block mt-lg">
            <p class="cta-block__eyebrow">Ready to get free?</p>
            <h2 class="cta-block__title">Kick porn to the curb.</h2>
            <p class="cta-block__body">
              Scientifically-backed accountability software that dramatically reduces porn usage.
              63% of users report zero porn use after one month. Guaranteed.
            </p>
            <a
              href="https://everaccountable.com/fighting-porn-together/"
              target="_blank"
              rel="noopener"
              class="btn btn--primary"
            >
              Get Free From Lies <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </div>

        <!-- Prev / Next lie navigation -->
        <nav class="lie-detail__nav" aria-label="Previous and next lies">
          <div>
            {prevLie && (
              <a href={`/lies/${prevLie.slug}`} class="lie-nav-link lie-nav-link--prev">
                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                <span>
                  <small>Previous lie</small>
                  <strong>{prevLie.title}</strong>
                </span>
              </a>
            )}
          </div>
          <a href="/lies" class="btn btn--outline btn--sm">All Lies</a>
          <div>
            {nextLie && (
              <a href={`/lies/${nextLie.slug}`} class="lie-nav-link lie-nav-link--next">
                <span>
                  <small>Next lie</small>
                  <strong>{nextLie.title}</strong>
                </span>
                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
              </a>
            )}
          </div>
        </nav>
      </div>
    </div>
  </section>

  <!-- Newsletter sign-up at bottom -->
  <section class="section section--dark" aria-labelledby="lie-newsletter">
    <div class="container">
      <div class="cta-block">
        <p class="cta-block__eyebrow">Want to Stay Connected?</p>
        <h2 class="cta-block__title" id="lie-newsletter">Sign up for news and updates</h2>
        <LeadForm id={`lie-newsletter-${lie.slug}`} submitLabel="Sign Up" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.lie-detail__hero-section {
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.lie-detail__hero {
  text-align: center;
  max-width: 780px;
  margin-inline: auto;
}
.lie-detail__hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-style: italic;
  color: var(--color-white);
  margin-block: 0.5rem 1rem;
}
.lie-detail__content {
  max-width: 700px;
  margin-inline: auto;
}
.lie-detail__content p {
  font-size: clamp(1rem, 1.8vw, 1.15rem);
  line-height: 1.85;
  margin-bottom: 1.75rem;
  color: var(--color-text);
}
.lie-detail__nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-block: 2.5rem;
  border-top: 1px solid rgba(255,255,255,0.07);
  margin-top: 3rem;
  gap: 1rem;
  flex-wrap: wrap;
}
.lie-nav-link {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--color-text-muted);
  transition: color var(--transition-base);
  max-width: 220px;
}
.lie-nav-link:hover { color: var(--color-white); }
.lie-nav-link span {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.lie-nav-link small {
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent-red);
}
.lie-nav-link strong {
  font-size: 0.85rem;
  font-weight: 600;
  color: inherit;
}
.lie-nav-link--next {
  text-align: right;
  flex-direction: row-reverse;
}
.lie-nav-link--next span { align-items: flex-end; }
</style>
