---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — PornLies"
  description="This page doesn't exist."
>
  <section class="section" style="text-align: center; min-height: 60vh; display: flex; align-items: center;">
    <div class="container">
      <p style="font-size: 6rem; font-weight: 900; color: var(--color-accent-red); line-height: 1; margin-bottom: 1rem; opacity: 0.4;">404</p>
      <h1 style="margin-bottom: 1rem;">Porn lied about this page existing.</h1>
      <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
        The page you're looking for doesn't exist — but the truth does.
      </p>
      <div class="flex-center gap-md">
        <a href="/" class="btn btn--red">Go Home</a>
        <a href="/lies" class="btn btn--outline">See the Lies</a>
      </div>
    </div>
  </section>
</BaseLayout>
